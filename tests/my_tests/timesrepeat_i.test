+++ CONTROL
*** timesRepeat: passes iteration index into one-argument block
!I! 0
123

<?xml version="1.0" encoding="UTF-8"?>
<program language="SOL26">
  <class name="Main" parent="Object">
    <method selector="run">
      <block arity="0">
        <assign order="1">
          <var name="_"/>
          <expr>
            <send selector="timesRepeat:">
              <expr><literal class="Integer" value="3"/></expr>
              <arg order="1">
                <expr>
                  <block arity="1">
                    <parameter order="1" name="i"/>
                    <assign order="1">
                      <var name="_"/>
                      <expr>
                        <send selector="print">
                          <expr><var name="i"/></expr>
                        </send>
                      </expr>
                    </assign>
                  </block>
                </expr>
              </arg>
            </send>
          </expr>
        </assign>
      </block>
    </method>
  </class>
</program>
