+++ CONTROL
*** ifTrue:ifFalse: basic boolean branch
!I! 0
1

<?xml version="1.0" encoding="UTF-8"?>
<program language="SOL26">
  <class name="Main" parent="Object">
    <method selector="run">
      <block arity="0">
        <assign order="1">
          <var name="_"/>
          <expr>
            <send selector="ifTrue:ifFalse:">
              <expr><literal class="True" value="true"/></expr>
              <arg order="1">
                <expr>
                  <block arity="0">
                    <assign order="1">
                      <var name="_"/>
                      <expr>
                        <send selector="print">
                          <expr><literal class="String" value="YES"/></expr>
                        </send>
                      </expr>
                    </assign>
                  </block>
                </expr>
              </arg>
              <arg order="2">
                <expr>
                  <block arity="0">
                    <assign order="1">
                      <var name="_"/>
                      <expr>
                        <send selector="print">
                          <expr><literal class="String" value="NO"/></expr>
                        </send>
                      </expr>
                    </assign>
                  </block>
                </expr>
              </arg>
            </send>
          </expr>
        </assign>
      </block>
    </method>
  </class>
</program>
